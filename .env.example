# ApplyPilot Environment Configuration
# Copy to ~/.applypilot/.env and fill in your values.

# ---------------------------------------------------------------------------
# Pipeline LLM (score / tailor / cover) — enable ONE provider block only
# ---------------------------------------------------------------------------

# Option A: Google Gemini (free tier available)
# GEMINI_API_KEY=
# LLM_MODEL=gemini-2.0-flash

# Option B: Claude API (Anthropic) — https://console.anthropic.com
# ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
# LLM_MODEL=claude-haiku-4-5

# Option C: OpenAI
# OPENAI_API_KEY=
# LLM_MODEL=gpt-4o-mini

# Option D: OpenAI-compatible URL (Ollama, local proxy, enterprise gateway)
# LLM_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5-coder:14b
# LLM_API_KEY=                        # optional Bearer token for LLM_URL

# ---------------------------------------------------------------------------
# Auto-apply (separate from pipeline LLM above)
# Uses Claude Code CLI + your subscription — NOT configured here.
# Install: https://claude.ai/code  then: make apply MODEL=haiku
# ---------------------------------------------------------------------------

# Optional
# CAPSOLVER_API_KEY=                  # CAPTCHA solving during auto-apply
# PROXY=host:port:user:pass           # Scraping proxy
